import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import yfinance as yf

# Example Mutual Fund (use ETF as proxy, since MF data is limited)
funds = {
    "SBI ETF Nifty 50": "NIFTYBEES.NS",
    "ICICI Prudential Nifty ETF": "ICICINIFTY.NS"
}

# Fetch data
data = {}
for name, ticker in funds.items():
    df = yf.download(ticker, start="2020-01-01", end="2025-01-01")
    data[name] = df['Adj Close']

# Combine into single DataFrame
df = pd.DataFrame(data)

# Calculate Daily Returns
returns = df.pct_change()

# Calculate Cumulative Returns
cumulative_returns = (1 + returns).cumprod()

# Calculate Annualized Return
annual_returns = returns.mean() * 252

# Calculate Risk (Standard Deviation)
risk = returns.std() * np.sqrt(252)

# Sharpe Ratio (Assume risk-free rate = 5%)
risk_free_rate = 0.05
sharpe_ratio = (annual_returns - risk_free_rate) / risk

# Print Results
print("Annual Returns:\n", annual_returns)
print("\nRisk (Volatility):\n", risk)
print("\nSharpe Ratio:\n", sharpe_ratio)

# Plot Cumulative Returns
plt.figure(figsize=(10,5))
for col in cumulative_returns.columns:
    plt.plot(cumulative_returns[col], label=col)

plt.title("Mutual Fund Performance Comparison")
plt.xlabel("Date")
plt.ylabel("Growth of ₹1 Investment")
plt.legend()
plt.grid()
plt.show()
