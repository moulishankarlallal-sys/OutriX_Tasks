# Import libraries
import numpy as np

# Step 1: Calculate daily returns
returns = data.pct_change().dropna()

# Step 2: Annualized mean returns
mean_returns = returns.mean() * 252

# Step 3: Covariance matrix
cov_matrix = returns.cov() * 252

# Step 4: Define portfolio weights
weights = np.array([0.3, 0.4, 0.3])

# Step 5: Portfolio return
portfolio_return = np.sum(mean_returns * weights)

# Step 6: Portfolio risk (standard deviation)
portfolio_std = np.sqrt(np.dot(weights.T, np.dot(cov_matrix, weights)))

# Step 7: Sharpe Ratio
risk_free_rate = 0.05
sharpe_ratio = (portfolio_return - risk_free_rate) / portfolio_std

# Print results
print("Expected Portfolio Return:", round(portfolio_return,4))
print("Portfolio Risk (Std Dev):", round(portfolio_std,4))
print("Sharpe Ratio:", round(sharpe_ratio,4))
